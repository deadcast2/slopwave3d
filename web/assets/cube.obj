# Unit cube centered at origin
# CCW winding (standard OBJ convention)

v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5

vt 0 0
vt 1 0
vt 1 1
vt 0 1

vn  0  0  1
vn  0  0 -1
vn  1  0  0
vn -1  0  0
vn  0  1  0
vn  0 -1  0

# Front face (z+)
f 1/1/1 2/2/1 3/3/1 4/4/1

# Back face (z-)
f 5/1/2 8/4/2 7/3/2 6/2/2

# Right face (x+)
f 2/1/3 6/2/3 7/3/3 3/4/3

# Left face (x-)
f 5/1/4 1/2/4 4/3/4 8/4/4

# Top face (y+)
f 4/1/5 3/2/5 7/3/5 8/4/5

# Bottom face (y-)
f 5/1/6 6/2/6 2/3/6 1/4/6
