# Unit cube centered at origin
# CW winding for slop3d front faces

v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5

vt 0 0
vt 1 0
vt 1 1
vt 0 1

vn  0  0  1
vn  0  0 -1
vn  1  0  0
vn -1  0  0
vn  0  1  0
vn  0 -1  0

# Front face (z+) — CW from outside: 1,4,3,2
f 1/1/1 4/4/1 3/3/1 2/2/1

# Back face (z-) — CW from outside: 5,6,7,8
f 5/1/2 6/2/2 7/3/2 8/4/2

# Right face (x+) — CW from outside: 2,3,7,6
f 2/1/3 3/2/3 7/3/3 6/4/3

# Left face (x-) — CW from outside: 5,8,4,1
f 5/1/4 8/2/4 4/3/4 1/4/4

# Top face (y+) — CW from outside: 4,8,7,3
f 4/1/5 8/2/5 7/3/5 3/4/5

# Bottom face (y-) — CW from outside: 5,1,2,6
f 5/1/6 1/2/6 2/3/6 6/4/6
